generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  AGENT
  MANAGER
  PARTNER
}

enum BookingStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentType {
  FULL_PAYMENT
  PARTIAL_PAYMENT
}

enum BookingEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  DELETED
  PAYMENT_CREATED
  PAYMENT_COMPLETED
  PAYMENT_FAILED
  DISPUTE_CREATED
  DISPUTE_STATUS_CHANGED
}

enum InventoryStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum PartnerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PartnerEventType {
  INVITED
  INVITE_ACCEPTED
  APPROVED
  REJECTED
}

enum PaymentState {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum EscrowReleaseStatus {
  ON_HOLD
  SCHEDULED
  RELEASED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  APPROVED
  SENT
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PartnerServiceCategory {
  GET_AROUND
  VERIFIED_STAYS
  LIVE_LIKE_LOCAL
  EXPERT_ACCESS
  GEAR_UP
  GET_ENTERTAINED
}

enum PartnerServiceType {
  CAR
  DRIVER
  GUIDE
  PARK
  MOTO
  BOAT
  MASSAGE
  RESTAURANT
  SHOP
  LAUNDRY
}

enum City {
  NAIROBI
  MOMBASA
  DIANI_BEACH
  MALINDI
  KISUMU
  NAKURU
  ELDORET
  LAMU
  NANYUKI
  AMBOSELI
  WATAMU
  ZANZIBAR
  ARUSHA
  DAR_ES_SALAAM
}

enum GetAroundService {
  AIRPORT_TRANSFERS
  PRIVATE_DRIVERS
  CAR_RENTALS
  EV_CHARGING
  SCOOTER_BIKE_RENTALS
  TOURS
  CITY_TRANSFERS
}

enum VerifiedStaysService {
  BOUTIQUE_HOTELS
  VETTED_RENTALS
  ECO_LODGES
  LUXURY_CAMPS
}

enum LiveLikeLocalService {
  HOME_COOKED_MEALS
  NEIGHBORHOOD_WALKS
  LANGUAGE_EXCHANGE
  CULTURAL_LEARNING
}

enum ExpertAccessService {
  LAWYERS
  TOUR_GUIDES
  TRANSLATORS
  PHOTOGRAPHERS
  MEDICAL_ASSISTANTS
  SECURITY
  BUSINESS_SCOUTING
  INTERCONNECTIVITY_EXPERTS
  DELIVERY_SERVICES
  CLEANING_SERVICES
  EVENT_PLANNING
}

enum GearUpService {
  CAMPING_GEAR
  HIKING_EQUIPMENT
  TECH_RENTALS
}

enum GetEntertainedService {
  CLUB
  DINE_OUT
  MASSAGE_SPA
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum ReceiptStatus {
  ISSUED
  VOID
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  DECLINED
  PROCESSING
  COMPLETED
  FAILED
}

enum DispatchStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DispatchEventType {
  CREATED
  ASSIGNED
  STATUS_CHANGED
}

enum ShiftStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationType {
  REMINDER
  PROMO
  SOS
  COMMUNITY
}

enum NotificationPriority {
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENT
  FAILED
  CANCELLED
}

enum CommunityPostStatus {
  DRAFT
  PUBLISHED
  FLAGGED
  ARCHIVED
}

enum CommunityVisibility {
  PUBLIC
  MEMBERS_ONLY
}

enum CommunityReactionType {
  LIKE
  LOVE
  INSIGHTFUL
  CURIOUS
}

enum CommunityCommentStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum CommunitySubscriptionFrequency {
  INSTANT
  DAILY
}

enum OfferStatus {
  DRAFT
  APPROVED
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OfferAssetType {
  LOGO
  SIGNATURE
}

enum Currency {
  USD
  KES
}

model User {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  emailVerified     Boolean  @default(false)
  emailVerifiedAt   DateTime?
  password          String
  phone             String?
  phoneVerified     Boolean  @default(false)
  phoneVerifiedAt   DateTime?
  idNumber          String?
  idType            String?
  profilePicUrl     String?
  role              Role     @default(AGENT)
  isActive          Boolean  @default(true)
  partnerId         String?  @unique // Link to partner profile if user is a partner
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bookings         Booking[]
  quotes           Quote[]
  disputesOpened   Dispute[] @relation("DisputeOpenedBy")
  disputesAssigned Dispute[] @relation("DisputeAssignedTo")
  partnersApproved Partner[] @relation("PartnerApprovedBy")
  partner          Partner?  @relation("UserPartner")

  dispatchesAssigned Dispatch[] @relation("DispatchAssignedTo")
  shifts             AgentShift[]
  paymentsRecorded  Payment[]      @relation("PaymentRecordedBy")
  payoutsCreated    Payout[]       @relation("PayoutCreatedBy")
  notificationTemplates NotificationTemplate[] @relation("NotificationTemplateCreatedBy")
  notificationJobsCreated NotificationJob[] @relation("NotificationCreatedBy")
  notificationJobsTarget NotificationJob[] @relation("NotificationJobUser")
  notificationAttempts NotificationAttempt[] @relation("NotificationAttemptActor")
  offerTemplatesCreated OfferTemplate[] @relation("OfferTemplateCreatedBy")
  offerProposalsApproved OfferProposal[] @relation("OfferProposalApprovedBy")
  offerProposalsPublished OfferProposal[] @relation("OfferProposalPublishedBy")
  communityTopicsCreated CommunityTopic[] @relation("CommunityTopicCreatedBy")
  communityPostsAuthored CommunityPost[] @relation("CommunityPostAuthor")
  communityReactions CommunityReaction[] @relation("CommunityReactionUser")
  communityComments CommunityComment[] @relation("CommunityCommentUser")
  communitySubscriptions CommunitySubscription[] @relation("CommunitySubscriptionUser")
  refreshTokens    RefreshToken[]
}

model Booking {
  id                  String        @id @default(uuid())
  referenceNumber     String        @unique  // e.g. TF-202603-00042
  referenceSeq        Int                    // raw sequence for ordering/display
  customerName        String
  customerEmail       String?
  customerPhoneNumber String?
  serviceTitle        String
  pickupLocation      String?
  destination         String?
  numberOfGuests      Int?
  numberOfChildren    Int           @default(0)
  numberOfPets        Int           @default(0)
  notes               String?
  amount              Decimal       @db.Decimal(12, 2)
  currency            Currency      @default(USD)
  commissionRate      Decimal       @db.Decimal(5, 4)
  commissionAmount    Decimal       @db.Decimal(12, 2)
  commissionCurrency  Currency      @default(KES)
  status              BookingStatus @default(DRAFT)
  paymentStatus       PaymentStatus @default(UNPAID)
  paymentType         PaymentType   @default(FULL_PAYMENT)
  costAtBooking       Decimal?      @db.Decimal(12, 2)
  costPostEvent       Decimal?      @db.Decimal(12, 2)
  totalCost           Decimal?      @db.Decimal(12, 2)
  payPostEventDueDate DateTime?
  splitPaymentEnabled Boolean       @default(false)
  depositPercentage   Decimal?      @db.Decimal(5, 4)
  depositAmount       Decimal?      @db.Decimal(12, 2)
  depositDueDate      DateTime?
  balanceAmount       Decimal?      @db.Decimal(12, 2)
  balanceDueDate      DateTime?
  splitPaymentNotes   String?
  agentId             String
  serviceStartAt      DateTime?
  serviceEndAt        DateTime?
  serviceTimezone     String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  agent             User             @relation(fields: [agentId], references: [id])
  bookingPartners   BookingPartner[] @relation("BookingPartners")
  events            BookingEvent[]
  payments          Payment[]
  quotes            Quote[]
  contracts         Contract[]
  receipts          Receipt[]
  disputes          Dispute[]
  refunds           Refund[]
  dispatches        Dispatch[]
  escrow            EscrowAccount?
  payouts           Payout[]
  shifts            AgentShift[]
  notifications     NotificationJob[]
  offers            OfferProposal[]

  @@index([agentId])
  @@index([referenceNumber])
}

model BookingPartner {
  id                  String        @id @default(uuid())
  bookingId           String
  partnerId           String
  partnerServiceId    String?       // optional link to a specific PartnerService listing
  partnerName         String
  partnerPhoneNumber  String?
  description         String?
  costAtBooking       Decimal       @db.Decimal(12, 2)
  costPostEvent       Decimal       @db.Decimal(12, 2) @default(0)
  totalCost           Decimal       @db.Decimal(12, 2)
  paymentStatus       PaymentStatus @default(UNPAID)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  booking             Booking        @relation("BookingPartners", fields: [bookingId], references: [id], onDelete: Cascade)
  partner             Partner        @relation(fields: [partnerId], references: [id])
  partnerService      PartnerService? @relation(fields: [partnerServiceId], references: [id])

  @@index([bookingId])
  @@index([partnerId])
  @@index([partnerServiceId])
  @@unique([bookingId, partnerId])
}

model PartnerService {
  id               String                 @id @default(uuid())
  partnerId        String
  serviceCategory  PartnerServiceCategory
  serviceType      PartnerServiceType
  description      String?                // e.g. "Toyota Axio Hybrid", "Car With Driver"

  // Car-specific
  carType          String?                // e.g. "Compact", "SUV", "Minivan"
  selfDrive        Boolean?

  // Boat-specific
  boatCapacity     Int?

  // Restaurant-specific
  cuisine          String?

  // General
  priceFrom        Decimal?               @db.Decimal(12, 2)
  currency         Currency               @default(KES)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  partner          Partner                @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  cities           PartnerServiceCity[]
  bookingPartners  BookingPartner[]

  @@index([partnerId])
  @@index([serviceType])
  @@index([serviceCategory])
}

model PartnerServiceCity {
  id               String         @id @default(uuid())
  partnerServiceId String
  city             City

  partnerService   PartnerService @relation(fields: [partnerServiceId], references: [id], onDelete: Cascade)

  @@unique([partnerServiceId, city])
  @@index([partnerServiceId])
  @@index([city])
}

model BookingEvent {
  id        String           @id @default(uuid())
  bookingId String
  type      BookingEventType
  actorId   String?
  metadata  Json?
  createdAt DateTime         @default(now())

  booking   Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

// Counter table for per-month sequential reference numbers
model BookingSequence {
  id      String @id  // e.g. "2026-03"
  lastSeq Int    @default(0)
}

model Partner {
  id              String          @id @default(uuid())
  userId          String          @unique // Linked to User
  businessName    String?
  website         String?
  description     String?
  isActive        Boolean         @default(true)
  approvalStatus  PartnerApprovalStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Store selected services as JSON arrays for flexibility
  serviceCategories   String[]  // PartnerServiceCategory[] as strings
  getAroundServices   String[]  // GetAroundService[] as strings
  verifiedStaysServices String[]  // VerifiedStaysService[] as strings
  liveLikeLocalServices String[]  // LiveLikeLocalService[] as strings
  expertAccessServices String[]  // ExpertAccessService[] as strings
  gearUpServices      String[]  // GearUpService[] as strings
  getEntertainedServices String[]  // GetEntertainedService[] as strings

  user            User       @relation("UserPartner", fields: [userId], references: [id], onDelete: Cascade)
  inventory       InventoryItem[]
  contracts       Contract[]
  events          PartnerEvent[]
  bookingPartners BookingPartner[]
  partnerServices PartnerService[]
  approvedBy      User?      @relation("PartnerApprovedBy", fields: [approvedById], references: [id])

  @@index([approvalStatus])
  @@index([userId])
  @@index([approvedById])
}

model PartnerEvent {
  id        String           @id @default(uuid())
  partnerId String
  type      PartnerEventType
  actorId   String?
  metadata  Json?
  createdAt DateTime         @default(now())

  partner   Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
}



model Dispatch {
  id           String         @id @default(uuid())
  bookingId    String
  assignedToId String?
  status       DispatchStatus @default(PENDING)
  notes        String?
  startedAt    DateTime?
  metadata     Json?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())

  booking      Booking        @relation(fields: [bookingId], references: [id])
  assignedTo   User?          @relation("DispatchAssignedTo", fields: [assignedToId], references: [id])
  trackPoints  DispatchTrackPoint[]
  events       DispatchEvent[]

  @@index([bookingId])
  @@index([assignedToId])
}

model DispatchEvent {
  id         String            @id @default(uuid())
  dispatchId String
  type       DispatchEventType
  actorId    String?
  metadata   Json?
  createdAt  DateTime          @default(now())

  dispatch   Dispatch          @relation(fields: [dispatchId], references: [id], onDelete: Cascade)

  @@index([dispatchId])
  @@index([createdAt])
}

model AgentShift {
  id        String      @id @default(uuid())
  agentId   String
  bookingId String?
  startAt   DateTime
  endAt     DateTime
  status    ShiftStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  agent   User    @relation(fields: [agentId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([agentId])
  @@index([bookingId])
  @@index([startAt])
}

model DispatchTrackPoint {
  id         String   @id @default(uuid())
  dispatchId String
  latitude   Decimal  @db.Decimal(9, 6)
  longitude  Decimal  @db.Decimal(9, 6)
  recordedAt DateTime @default(now())
  metadata   Json?

  dispatch   Dispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)

  @@index([dispatchId])
  @@index([recordedAt])
}

model InventoryItem {
  id          String          @id @default(uuid())
  partnerId   String
  title       String
  description String?
  price       Decimal         @db.Decimal(12, 2)
  status      InventoryStatus @default(DRAFT)
  createdAt   DateTime        @default(now())

  partner     Partner         @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
}

model Payment {
  id            String       @id @default(uuid())
  bookingId     String
  provider      String
  amount        Decimal      @db.Decimal(12, 2)
  currency      Currency     @default(USD)
  state         PaymentState @default(INITIATED)
  reference     String?      @unique
  metadata      Json?
  createdAt     DateTime     @default(now())
  recordedById  String?

  booking       Booking      @relation(fields: [bookingId], references: [id])
  recordedBy    User?        @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  receipts      Receipt[]
  refunds       Refund[]

  @@index([bookingId])
  @@index([recordedById])

}


model EscrowAccount {
  id               String               @id @default(uuid())
  bookingId        String               @unique
  totalAmount      Decimal              @db.Decimal(12, 2) @default(0)
  releasedAmount   Decimal              @db.Decimal(12, 2) @default(0)
  currency         Currency             @default(USD)
  releaseStatus    EscrowReleaseStatus  @default(ON_HOLD)
  releaseScheduledAt DateTime?
  releasedAt       DateTime?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  booking          Booking              @relation(fields: [bookingId], references: [id])
  payouts          Payout[]         @relation("EscrowAccountPayouts")
}

model Payout {
  id          String       @id @default(uuid())
  bookingId   String
  escrowAccountId String?
  amount      Decimal      @db.Decimal(12, 2)
  currency    Currency     @default(USD)
  status      PayoutStatus @default(PENDING)
  notes       String?
  metadata    Json?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  booking   Booking @relation(fields: [bookingId], references: [id])
  escrowAccount EscrowAccount? @relation("EscrowAccountPayouts", fields: [escrowAccountId], references: [id])
  createdBy User?   @relation("PayoutCreatedBy", fields: [createdById], references: [id])

  @@index([bookingId])
  @@index([escrowAccountId])
  @@index([createdById])
}

model NotificationTemplate {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  type        NotificationType
  channel     NotificationChannel
  subject     String?
  body        String
  tokens      Json?
  metadata    Json?
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  createdBy   User?              @relation("NotificationTemplateCreatedBy", fields: [createdById], references: [id])
  jobs        NotificationJob[]
}

model NotificationJob {
  id              String              @id @default(uuid())
  templateId      String?
  type            NotificationType
  channel         NotificationChannel
  priority        NotificationPriority @default(NORMAL)
  status          NotificationStatus  @default(SCHEDULED)
  subject         String?
  body            String?
  payload         Json?
  metadata        Json?
  scheduledAt     DateTime
  processedAt     DateTime?
  sentAt          DateTime?
  error           String?
  attempts        Int                 @default(0)
  recipientName   String?
  recipientEmail  String?
  recipientPhone  String?
  bookingId       String?
  userId          String?
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  template   NotificationTemplate? @relation(fields: [templateId], references: [id])
  booking    Booking?              @relation(fields: [bookingId], references: [id])
  user       User?                 @relation("NotificationJobUser", fields: [userId], references: [id])
  createdBy  User?                 @relation("NotificationCreatedBy", fields: [createdById], references: [id])
  attemptsLog NotificationAttempt[]

  @@index([status, scheduledAt])
  @@index([bookingId])
  @@index([userId])
}

model NotificationAttempt {
  id        String             @id @default(uuid())
  jobId     String
  status    NotificationStatus
  channel   NotificationChannel
  response  Json?
  error     String?
  actorId   String?
  createdAt DateTime           @default(now())

  job    NotificationJob      @relation(fields: [jobId], references: [id])
  actor  User?                @relation("NotificationAttemptActor", fields: [actorId], references: [id])

  @@index([jobId])
}

model OfferTemplate {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  defaultCurrency Currency @default(USD)
  baseAmount   Decimal?  @db.Decimal(12, 2)
  feePercentage Decimal? @db.Decimal(5, 4)
  itinerary    Json?
  addons       Json?
  assetConfig  Json?
  metadata     Json?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy User? @relation("OfferTemplateCreatedBy", fields: [createdById], references: [id])
  proposals OfferProposal[]
  mediaAssets OfferAsset[] @relation("OfferTemplateAssets")
}

model OfferProposal {
  id            String      @id @default(uuid())
  bookingId     String
  templateId    String?
  status        OfferStatus @default(DRAFT)
  currency      Currency    @default(USD)
  baseAmount    Decimal     @db.Decimal(12, 2)
  feeAmount     Decimal     @db.Decimal(12, 2)
  discountAmount Decimal    @db.Decimal(12, 2)
  totalAmount   Decimal     @db.Decimal(12, 2)
  feePercentage Decimal     @db.Decimal(5, 4)
  discountRate  Decimal     @db.Decimal(5, 4)
  itinerary     Json?
  priceBreakdown Json?
  notes         String?
  pdfUrl        String?
  logoUrl       String?
  signatureUrl  String?
  expiresAt     DateTime?
  metadata      Json?
  approvedById  String?
  approvedAt    DateTime?
  approvalNotes String?
  publishedById String?
  publishedAt   DateTime?
  publishedChannel String?
  publishNotes  String?
  shareSlug     String?    @unique
  shareUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  booking   Booking      @relation(fields: [bookingId], references: [id])
  template  OfferTemplate? @relation(fields: [templateId], references: [id])
  assets    OfferAsset[] @relation("OfferProposalAssets")
  approvedBy User? @relation("OfferProposalApprovedBy", fields: [approvedById], references: [id])
  publishedBy User? @relation("OfferProposalPublishedBy", fields: [publishedById], references: [id])

  @@index([bookingId])
  @@index([templateId])
  @@index([approvedById])
  @@index([publishedById])
}

model OfferAsset {
  id          String         @id @default(uuid())
  proposalId  String?
  templateId  String?
  type        OfferAssetType
  url         String
  metadata    Json?
  createdAt   DateTime       @default(now())

  proposal OfferProposal? @relation("OfferProposalAssets", fields: [proposalId], references: [id])
  template OfferTemplate? @relation("OfferTemplateAssets", fields: [templateId], references: [id])

  @@index([proposalId])
  @@index([templateId])
}

model CommunityTopic {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  metadata    Json?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("CommunityTopicCreatedBy", fields: [createdById], references: [id])
  posts     CommunityPost[]
  subscriptions CommunitySubscription[] @relation("CommunityTopicSubscriptions")

  @@unique([name])
  @@index([createdById])
}

model CommunityPost {
  id             String               @id @default(uuid())
  title          String
  slug           String               @unique
  content        String
  excerpt        String?
  coverImage     String?
  tags           Json?
  metadata       Json?
  status         CommunityPostStatus  @default(DRAFT)
  visibility     CommunityVisibility  @default(PUBLIC)
  isPinned       Boolean              @default(false)
  pinnedAt       DateTime?
  publishedAt    DateTime?
  lastActivityAt DateTime             @default(now())
  reactionCount  Int                  @default(0)
  commentCount   Int                  @default(0)
  authorId       String
  topicId        String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  author User            @relation("CommunityPostAuthor", fields: [authorId], references: [id])
  topic  CommunityTopic? @relation(fields: [topicId], references: [id])
  reactions CommunityReaction[]
  comments  CommunityComment[]
  subscriptions CommunitySubscription[] @relation("CommunityPostSubscriptions")

  @@index([authorId])
  @@index([topicId])
  @@index([status])
  @@index([visibility])
  @@index([isPinned, lastActivityAt])
}

model CommunityReaction {
  id        String                @id @default(uuid())
  postId    String
  userId    String
  type      CommunityReactionType @default(LIKE)
  createdAt DateTime              @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation("CommunityReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model CommunityComment {
  id        String                 @id @default(uuid())
  postId    String
  parentId  String?
  userId    String
  content   String
  status    CommunityCommentStatus @default(PUBLISHED)
  metadata  Json?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  post     CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User           @relation("CommunityCommentUser", fields: [userId], references: [id], onDelete: Cascade)
  parent   CommunityComment? @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  children CommunityComment[] @relation("CommentThread")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
}

model CommunitySubscription {
  id        String                        @id @default(uuid())
  userId    String
  topicId   String?
  postId    String?
  frequency CommunitySubscriptionFrequency @default(INSTANT)
  metadata  Json?
  createdAt DateTime                      @default(now())
  updatedAt DateTime                      @updatedAt

  user  User            @relation("CommunitySubscriptionUser", fields: [userId], references: [id], onDelete: Cascade)
  topic CommunityTopic? @relation("CommunityTopicSubscriptions", fields: [topicId], references: [id], onDelete: Cascade)
  post  CommunityPost?  @relation("CommunityPostSubscriptions", fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([topicId])
  @@index([postId])
  @@unique([userId, topicId])
  @@unique([userId, postId])
}

model Quote {
  id               String      @id @default(uuid())
  bookingId        String
  agentId          String
  title            String
  status           QuoteStatus @default(DRAFT)
  amount           Decimal     @db.Decimal(12, 2)
  currency         Currency    @default(USD)
  commissionRate   Decimal     @db.Decimal(5, 4)
  commissionAmount Decimal     @db.Decimal(12, 2)
  commissionCurrency Currency  @default(KES)
  expiresAt        DateTime?
  items            Json?
  notes            String?
  createdAt        DateTime    @default(now())

  booking          Booking     @relation(fields: [bookingId], references: [id])
  agent            User        @relation(fields: [agentId], references: [id])

  @@index([bookingId])
  @@index([agentId])
}

model Contract {
  id          String         @id @default(uuid())
  bookingId   String
  partnerId   String?
  status      ContractStatus @default(DRAFT)
  fileUrl     String?
  signedAt    DateTime?
  metadata    Json?
  createdAt   DateTime       @default(now())

  booking     Booking        @relation(fields: [bookingId], references: [id])
  partner     Partner?       @relation(fields: [partnerId], references: [id])

  @@index([bookingId])
  @@index([partnerId])
}

model Receipt {
  id            String        @id @default(uuid())
  bookingId     String
  paymentId     String
  receiptNumber String        @unique
  status        ReceiptStatus @default(ISSUED)
  amount        Decimal       @db.Decimal(12, 2)
  currency      Currency      @default(USD)
  issuedAt      DateTime      @default(now())
  fileUrl       String?

  booking       Booking       @relation(fields: [bookingId], references: [id])
  payment       Payment       @relation(fields: [paymentId], references: [id])

  @@index([bookingId])
  @@index([paymentId])
}

model Dispute {
  id           String        @id @default(uuid())
  bookingId    String
  status       DisputeStatus @default(OPEN)
  reason       String
  description  String?
  openedById   String
  assignedToId String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())

  booking      Booking       @relation(fields: [bookingId], references: [id])
  openedBy     User          @relation("DisputeOpenedBy", fields: [openedById], references: [id])
  assignedTo   User?         @relation("DisputeAssignedTo", fields: [assignedToId], references: [id])

  @@index([bookingId])
  @@index([openedById])
  @@index([assignedToId])
}

model Refund {
  id          String       @id @default(uuid())
  bookingId   String
  paymentId   String
  amount      Decimal      @db.Decimal(12, 2)
  currency    Currency     @default(USD)
  status      RefundStatus @default(REQUESTED)
  reason      String
  reference   String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())

  booking     Booking      @relation(fields: [bookingId], references: [id])
  payment     Payment      @relation(fields: [paymentId], references: [id])

  @@index([bookingId])
  @@index([paymentId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PhoneOtp {
  id        String   @id @default(uuid())
  phone     String   @unique
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}
