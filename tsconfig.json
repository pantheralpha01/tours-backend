{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/modules/community/__tests__",
    "src/modules/bookings/__tests__",
    "src/modules/inventory/__tests__",
    "src/modules/payments/__tests__",
    "src/modules/quotes/__tests__",
    "src/modules/receipts/__tests__",
    "src/modules/refunds/__tests__",
    "src/modules/invoices",
    "src/modules/bookings/booking.mapper.ts",
    "src/modules/auth/email-action.repository.ts",
    "src/**/*.old.ts"
  ]
}